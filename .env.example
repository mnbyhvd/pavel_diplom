# ── PostgreSQL ─────────────────────────────────────────────────
# Strong password for the DB (change before deploying!)
POSTGRES_PASSWORD=change_me_strong_password

# ── Spotify OAuth ──────────────────────────────────────────────
# Get credentials at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Must match EXACTLY what you set in Spotify dashboard → Redirect URIs
# Local dev:   http://127.0.0.1:8000/auth/callback
# Production:  https://YOUR_DOMAIN.com/auth/callback
SPOTIFY_REDIRECT_URI=https://YOUR_DOMAIN.com/auth/callback
